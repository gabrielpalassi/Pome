{
  "name": "pome",
  "version": "0.2.1",
  "description": "iCloud Drive for your Linux desktop.",
  "type": "module",
  "bin": {
    "pome": "dist/pome.js"
  },
  "scripts": {
    "build": "tsc",
    "flatpak-install": "rm -rf build-dir .flatpak-builder && flatpak-builder --user --install --force-clean build-dir io.github.gabrielpalassi.Pome.local.yml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "check": "npm run typecheck && npm run lint && npm run fmt",
    "check:fix": "npm run typecheck && npm run lint:fix && npm run fmt:fix"
  },
  "dependencies": {
    "dbus-next": "0.10.2",
    "puppeteer-core": "24.42.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
